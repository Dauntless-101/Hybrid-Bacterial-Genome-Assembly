import csv
import os
import sys

configfile: "../config/config.yaml"

# -----------------------------------------------------------------------------
# Validation & sample loading
# -----------------------------------------------------------------------------
def validate_samples(sheet_path):
    if not os.path.exists(sheet_path):
        print(f"Error: sample sheet '{sheet_path}' not found.", file=sys.stderr)
        sys.exit(1)
    samples = {}
    with open(sheet_path, newline="") as f:
        reader = csv.DictReader(f, delimiter="\t")
        for row in reader:
            sample = row["sample"].strip()
            r1 = row["r1"].strip()
            r2 = row["r2"].strip()
            lr = row["long_reads"].strip()
            for path, desc in [(r1, "R1"), (r2, "R2"), (lr, "long reads")]:
                if not os.path.exists(path):
                    print(f"Error: sample '{sample}' {desc} file not found: {path}", file=sys.stderr)
                    sys.exit(1)
            samples[sample] = {"r1": r1, "r2": r2, "long_reads": lr}
    return samples

SAMPLES = validate_samples(config["sample_sheet"])

# Bakta DB check
bakta_db = config["bakta"]["db_path"]
if not os.path.isdir(bakta_db):
    print(f"Error: Bakta database not found at {bakta_db}", file=sys.stderr)
    print(f"Download it with: bakta_db download --output {bakta_db}", file=sys.stderr)
    sys.exit(1)

